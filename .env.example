# URL de la API del Backend (Astro la valida en compilación de forma fail-fast)
API_URL=https://api.example.com
PUBLIC_N8N_WEBHOOK_URL=https://n8n.example.com/webhook/contact

# ==============================================================================
# Sentry Configuration
# ==============================================================================

# DSN Público de Sentry (Requerido para capturar errores del navegador)
PUBLIC_SENTRY_DSN=https://yourPublicKey@o0.ingest.sentry.io/yourProject

# Token de autenticación de Sentry (Privado, solo se usa en compilación para subir Source Maps)
SENTRY_AUTH_TOKEN=your_sentry_auth_token_here

# ==============================================================================
# Analíticas y Protección contra Bots
# ==============================================================================

# Clave de Sitio (Site Key) de Cloudflare Turnstile (opcional, usa la de pruebas por defecto)
PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# ID del Sitio de Umami Analytics (opcional, activa la inyección si se provee)
PUBLIC_UMAMI_WEBSITE_ID=

# URL del Script de Umami Analytics (opcional, usa la dirección por defecto si no se especifica)
PUBLIC_UMAMI_SCRIPT_URL=https://analiticas.midominio.com/script.js

# ID del Proyecto de Microsoft Clarity (opcional, activa la inyección si se provee)
PUBLIC_CLARITY_PROJECT_ID=
