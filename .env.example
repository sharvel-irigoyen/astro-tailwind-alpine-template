# URL de la API del Backend (Astro la valida en compilación de forma fail-fast)
API_URL=https://api.example.com

# ==============================================================================
# Sentry Configuration
# ==============================================================================

# DSN Público de Sentry (Requerido para capturar errores del navegador)
PUBLIC_SENTRY_DSN=https://yourPublicKey@o0.ingest.sentry.io/yourProject

# Token de autenticación de Sentry (Privado, solo se usa en compilación para subir Source Maps)
SENTRY_AUTH_TOKEN=your_sentry_auth_token_here
