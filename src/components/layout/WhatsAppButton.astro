---
import { siteConfig } from '../../config/site';

const whatsappUrl = `https://wa.me/${siteConfig.contact.whatsapp}?text=${encodeURIComponent(siteConfig.contact.whatsappMessage)}`;
---

<a
  href={whatsappUrl}
  target="_blank"
  rel="noopener noreferrer"
  class="group fixed right-6 bottom-6 z-40 flex h-14 w-14 items-center justify-center rounded-full bg-[#25d366] text-white shadow-lg transition-all hover:scale-110 hover:bg-[#128c7e] focus:ring-4 focus:ring-[#25d366]/40 focus:outline-none active:scale-95"
  aria-label="Contactar por WhatsApp"
>
  <!-- Efecto de Ondas de Pulso -->
  <span
    class="absolute inset-0 -z-10 animate-ping rounded-full bg-[#25d366]/60 opacity-75 group-hover:animate-none"
  ></span>

  <!-- Icono de WhatsApp SVG -->
  <svg
    class="h-8 w-8"
    fill="currentColor"
    viewBox="0 0 24 24"
    aria-hidden="true"
  >
    <path
      fill-rule="evenodd"
      d="M12 2C6.477 2 2 6.477 2 12c0 1.89.525 3.66 1.438 5.16L2 22l4.98-1.39C8.423 21.49 10.155 22 12 22c5.523 0 10-4.477 10-10S17.523 2 12 2zm5.83 14.16c-.23.65-1.34 1.19-1.85 1.23-.45.04-.9.18-2.9-.62-2.56-1.02-4.18-3.64-4.31-3.81-.13-.17-1.03-1.37-1.03-2.61 0-1.24.65-1.85.88-2.1.23-.25.5-.31.67-.31h.48c.15 0 .36-.06.57.44.22.52.74 1.8.8 1.93.06.12.1.27.02.43-.08.16-.12.26-.25.41-.12.15-.27.34-.38.45-.13.13-.27.27-.12.53.15.26.68 1.12 1.46 1.82.78.7 1.44 1.15 1.72 1.28.27.13.43.11.59-.08.16-.19.68-.79.86-1.06.18-.27.36-.22.61-.13.25.09 1.58.74 1.85.88.27.13.45.2.52.32.07.12.07.7-.16 1.35z"
      clip-rule="evenodd"></path>
  </svg>
</a>
