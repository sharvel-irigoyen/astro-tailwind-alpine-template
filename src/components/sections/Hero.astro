---
import { Picture } from 'astro:assets';
import { siteConfig } from '../../config/site';
import heroImage from '../../assets/placeholder-hero.png';
import Button from '../primitives/Button.astro';
---

<section
  class="dark:to-bg-dark relative overflow-hidden bg-gradient-to-b from-slate-50 to-white py-20 lg:py-28 dark:from-slate-900"
>
  <!-- Efectos de Fondo Premium (Burbujas/Gradientes) -->
  <div
    class="bg-primary/10 dark:bg-primary/5 pointer-events-none absolute -top-40 -left-40 h-[600px] w-[600px] rounded-full blur-3xl"
  >
  </div>
  <div
    class="bg-accent/10 dark:bg-accent/5 pointer-events-none absolute top-1/2 -right-40 h-[500px] w-[500px] rounded-full blur-3xl"
  >
  </div>

  <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 gap-12 lg:grid-cols-2 lg:items-center">
      <!-- Columna Izquierda: Mensajes y Conversión -->
      <div class="max-w-2xl space-y-6">
        <div
          class="bg-primary/10 text-primary dark:bg-primary/20 inline-flex items-center space-x-2 rounded-full px-3 py-1 text-sm font-semibold"
        >
          <span>100% Optimizado para Google</span>
          <svg
            class="h-4 w-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2.5"
              d="M9 5l7 7-7 7"></path>
          </svg>
        </div>

        <h1
          class="text-secondary text-4xl font-extrabold tracking-tight sm:text-5xl lg:text-6xl dark:text-white"
        >
          {siteConfig.name}
        </h1>

        <p class="text-primary dark:text-accent text-xl font-medium">
          {siteConfig.tagline}
        </p>

        <p class="text-lg leading-relaxed text-slate-600 dark:text-slate-400">
          {siteConfig.description}
        </p>

        <div class="flex flex-wrap gap-4 pt-2">
          <Button href="/contacto/" variant="primary">
            Obtener Asesoría Gratis
          </Button>
          <Button href="/servicios/" variant="outline"> Ver Servicios </Button>
        </div>
      </div>

      <!-- Columna Derecha: Imagen/Mockup con Picture -->
      <div class="relative flex justify-center lg:justify-end">
        <div class="relative w-full max-w-md lg:max-w-none">
          <!-- Decoración detrás de la imagen -->
          <div
            class="bg-primary/20 dark:bg-primary/10 absolute inset-0 -z-10 translate-x-3 translate-y-3 rounded-2xl"
          >
          </div>

          <Picture
            src={heroImage}
            alt={`Presentación de ${siteConfig.name}`}
            class="w-full rounded-2xl border border-slate-200/50 object-cover shadow-2xl dark:border-slate-800/50"
            width={600}
            height={400}
            quality={85}
            formats={['avif', 'webp']}
            fallbackFormat="png"
            priority
          />
        </div>
      </div>
    </div>
  </div>
</section>
