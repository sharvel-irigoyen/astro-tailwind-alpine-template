---
import type { TestimonialItem } from '../../types';
import SectionHeading from '../primitives/SectionHeading.astro';

interface Props {
  items: TestimonialItem[];
}

const { items } = Astro.props;
---

<section class="dark:bg-bg-dark overflow-hidden bg-white py-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <SectionHeading
      eyebrow="Casos de Éxito"
      title="Lo que dicen nuestros clientes"
      description="La confianza y los resultados comerciales de quienes ya confían en nosotros respaldan nuestro trabajo diario."
    />

    <!-- Lista de Testimonios (Grid Responsive) -->
    <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
      {
        items.map((testimonial) => (
          <div class="flex flex-col justify-between rounded-2xl border border-slate-200 bg-slate-50/50 p-8 shadow-sm hover:shadow dark:border-slate-800 dark:bg-slate-900/30">
            <div class="space-y-4">
              {/* Estrellas de Valoración */}
              <div class="flex space-x-1 text-amber-500">
                {Array.from({ length: testimonial.stars }).map(() => (
                  <svg class="h-5 w-5 fill-current" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
              </div>

              {/* Texto de la Reseña */}
              <p class="text-sm leading-relaxed text-slate-600 italic dark:text-slate-400">
                "{testimonial.text}"
              </p>
            </div>

            {/* Perfil del Cliente */}
            <div class="mt-8 flex items-center space-x-4">
              <img
                src={testimonial.avatar}
                alt={testimonial.name}
                class="border-primary/20 dark:border-accent/20 h-12 w-12 rounded-full border-2 object-cover"
                loading="lazy"
              />
              <div>
                <h4 class="text-secondary text-sm font-bold dark:text-white">
                  {testimonial.name}
                </h4>
                <p class="text-xs text-slate-500 dark:text-slate-500">
                  {testimonial.role}, {testimonial.company}
                </p>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
