---
import { siteConfig } from '../../config/site';
import { PUBLIC_N8N_WEBHOOK_URL } from 'astro:env/client';

const webhookUrl = PUBLIC_N8N_WEBHOOK_URL || '';
---

{
  siteConfig.turnstile?.enabled && (
    <script
      src="https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit"
      async
      defer
      is:inline
    />
  )
}

<div
  x-data={`contactForm('${webhookUrl}', '${siteConfig.name}')`}
  class="w-full max-w-lg rounded-2xl border border-slate-200 bg-white p-8 shadow-lg dark:border-slate-800 dark:bg-slate-900"
>
  <h3 class="text-secondary text-2xl font-bold dark:text-white">
    Envíanos un mensaje
  </h3>
  <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">
    Te responderemos en menos de 24 horas hábiles.
  </p>
  <div
    x-show="isSuccess"
    x-transition
    class="mt-6 rounded-xl border border-emerald-200 bg-emerald-50 p-6 text-center dark:border-emerald-800 dark:bg-emerald-950/20"
    style="display: none;"
  >
    <div
      class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-emerald-100 text-emerald-600 dark:bg-emerald-900 dark:text-emerald-400"
    >
      <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"
        ><path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M5 13l4 4L19 7"></path></svg
      >
    </div>
    <h4
      class="mt-4 text-lg font-semibold text-emerald-800 dark:text-emerald-400"
    >
      ¡Mensaje enviado con éxito!
    </h4>
    <p class="mt-2 text-sm text-emerald-700 dark:text-emerald-500">
      Gracias por escribirnos. Nuestro equipo comercial se pondrá en contacto
      contigo pronto.
    </p>
    <button
      type="button"
      x-on:click="resetForm"
      class="mt-4 text-xs font-semibold tracking-wider text-emerald-800 uppercase underline hover:no-underline dark:text-emerald-400"
      >Enviar otro mensaje</button
    >
  </div>
  <form
    x-show="isNotSuccess"
    x-on:submit.prevent="handleSubmit"
    novalidate
    class="mt-6 space-y-5"
  >
    <div>
      <label
        for="name"
        class="text-secondary block text-sm font-semibold dark:text-slate-300"
        >Nombre Completo <span class="text-primary">*</span></label
      >
      <input
        type="text"
        id="name"
        x-model="name"
        x-on:blur="touch('name')"
        x-bind:class="nameInputClass"
        placeholder="Ej. Juan Pérez"
      />
      <span
        x-show="showNameError"
        class="mt-1 block text-xs text-rose-500 dark:text-rose-400"
        style="display: none;">El nombre debe tener al menos 3 caracteres.</span
      >
    </div>
    <div>
      <label
        for="email"
        class="text-secondary block text-sm font-semibold dark:text-slate-300"
        >Correo Electrónico <span class="text-primary">*</span></label
      >
      <input
        type="email"
        id="email"
        x-model="email"
        x-on:blur="touch('email')"
        x-bind:class="emailInputClass"
        placeholder="juan@correo.com"
      />
      <span
        x-show="showEmailError"
        class="mt-1 block text-xs text-rose-500 dark:text-rose-400"
        style="display: none;">Ingresa un correo electrónico válido.</span
      >
    </div>
    <div>
      <label
        for="phone"
        class="text-secondary block text-sm font-semibold dark:text-slate-300"
        >Teléfono / Celular <span class="text-xs font-normal text-slate-500"
          >(Opcional)</span
        ></label
      >
      <input
        type="tel"
        id="phone"
        x-model="phone"
        placeholder="Ej. +51 987 654 321"
        class="text-secondary focus:border-primary focus:ring-primary/20 dark:focus:border-primary mt-1.5 w-full rounded-lg border border-slate-300 bg-slate-50 px-4 py-2.5 text-sm placeholder-slate-400 focus:bg-white focus:ring-4 focus:outline-none dark:border-slate-700 dark:bg-slate-800 dark:text-white dark:focus:bg-slate-900"
      />
    </div>
    <div>
      <label
        for="message"
        class="text-secondary block text-sm font-semibold dark:text-slate-300"
        >Mensaje <span class="text-primary">*</span></label
      >
      <textarea
        id="message"
        x-model="message"
        x-on:blur="touch('message')"
        x-bind:class="messageInputClass"
        rows="4"
        placeholder="Cuéntanos sobre tu proyecto o consulta..."></textarea>
      <div class="mt-1.5 flex items-center justify-between">
        <div>
          <span
            x-show="showMessageError"
            class="block text-xs text-rose-500 dark:text-rose-400"
            style="display: none;"
            >El mensaje debe tener al menos 10 caracteres.</span
          >
        </div>
        <span class="block text-right text-xs text-slate-400"
          >Mínimo 10 caracteres</span
        >
      </div>
    </div>
    <div
      x-show="isError"
      x-transition
      class="rounded-lg border border-rose-200 bg-rose-50 p-4 dark:border-rose-800 dark:bg-rose-950/20"
      style="display: none;"
    >
      <p
        class="text-xs font-semibold text-rose-800 dark:text-rose-400"
        x-text="errorMessage"
      >
      </p>
    </div>

    {
      siteConfig.turnstile?.enabled && (
        <div
          class="cf-turnstile mt-2"
          data-sitekey={siteConfig.turnstile.siteKey}
        />
      )
    }

    <button
      type="submit"
      x-bind:disabled="isSubmitDisabled"
      class="bg-primary hover:bg-primary-hover focus:ring-primary/20 flex w-full items-center justify-center rounded-lg px-5 py-3 text-sm font-semibold text-white shadow transition-all focus:ring-4 focus:outline-none disabled:cursor-not-allowed disabled:opacity-50"
    >
      <svg
        x-show="isSubmitting"
        class="mr-3 -ml-1 h-5 w-5 animate-spin text-white"
        fill="none"
        viewBox="0 0 24 24"
        style="display: none;"
        ><circle
          class="opacity-25"
          cx="12"
          cy="12"
          r="10"
          stroke="currentColor"
          stroke-width="4"></circle><path
          class="opacity-75"
          fill="currentColor"
          d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
        ></path></svg
      >
      <span x-text="submitButtonText">Enviar Mensaje</span>
    </button>
  </form>
</div>
