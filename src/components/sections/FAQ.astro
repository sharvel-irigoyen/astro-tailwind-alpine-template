---
import type { FaqItem } from '../../types';
import SectionHeading from '../primitives/SectionHeading.astro';

interface Props {
  items: FaqItem[];
}

const { items } = Astro.props;
---

<section class="bg-slate-50 py-20 dark:bg-slate-900/50">
  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
    <div class="reveal" data-reveal-direction="up" data-reveal-duration="0.8">
      <SectionHeading
        eyebrow="Preguntas Frecuentes"
        title="Resolvemos tus dudas"
        description="Todo lo que necesitas saber sobre el desarrollo de tu sitio web y nuestro proceso de trabajo."
      />
    </div>
    <div
      x-data="faqAccordion"
      class="reveal space-y-4"
      data-reveal-direction="up"
      data-reveal-delay="0.1"
      data-reveal-duration="0.8"
    >
      {
        items.map((item, index) => (
          <div
            class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm transition-all duration-350 dark:border-slate-800 dark:bg-slate-900"
            x-bind:class={`isOpen(${index}) ? 'border-primary/30 dark:border-accent/30 shadow-md ring-1 ring-primary/5 dark:ring-accent/5' : ''`}
          >
            <button
              type="button"
              class="text-secondary hover:text-primary dark:hover:text-accent flex w-full items-center justify-between px-6 py-5 text-left font-semibold transition-all duration-300 dark:text-white"
              x-on:click={`toggle(${index})`}
              x-bind:aria-expanded={`isOpen(${index})`}
              x-bind:class={`isOpen(${index}) ? 'bg-slate-50/50 dark:bg-slate-800/30' : ''`}
            >
              <span>{item.question}</span>
              <span class="ml-6 flex h-7 items-center">
                <svg
                  class="h-5 w-5 transform transition-transform duration-300"
                  x-bind:class={`getClass(${index})`}
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke-width="1.5"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M19.5 8.25l-7.5 7.5-7.5-7.5"
                  />
                </svg>
              </span>
            </button>
            <div
              class="grid transition-[grid-template-rows,opacity] duration-300 ease-in-out"
              x-bind:class={`isOpen(${index}) ? 'grid-rows-[1fr] opacity-100' : 'grid-rows-[0fr] opacity-0'`}
            >
              <div class="overflow-hidden">
                <div class="border-t border-slate-100 px-6 py-5 dark:border-slate-800">
                  <p class="text-sm leading-relaxed text-slate-600 dark:text-slate-400">
                    {item.answer}
                  </p>
                </div>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
