---
import PageLayout from '../layouts/PageLayout.astro';
import { siteConfig } from '../config/site';
import { services } from '../data/services';

// Mapa de Iconos SVG para servicios
const icons: Record<string, string> = {
  web: `<svg class="h-8 w-8 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" /></svg>`,
  cart: `<svg class="h-8 w-8 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" /></svg>`,
  code: `<svg class="h-8 w-8 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" /></svg>`,
  search: `<svg class="h-8 w-8 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>`,
};
---

<PageLayout
  title={`Nuestros Servicios | ${siteConfig.name}`}
  description={`Conoce las soluciones digitales que ofrecemos en ${siteConfig.name}: diseño web rápido, tiendas de comercio electrónico e integraciones a medida.`}
>
  <main class="dark:bg-bg-dark bg-slate-50 py-16 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <!-- Encabezado de Página -->
      <div
        class="reveal mx-auto mb-20 max-w-3xl text-center"
        data-reveal-direction="up"
        data-reveal-duration="0.8"
      >
        <h1
          class="text-secondary text-4xl font-extrabold tracking-tight sm:text-5xl dark:text-white"
        >
          Nuestras Soluciones Digitales
        </h1>
        <p class="mt-4 text-lg text-slate-600 dark:text-slate-400">
          Desarrollamos herramientas rápidas y seguras para que tu negocio
          destaque en internet, capte leads y automatice procesos comerciales.
        </p>
      </div>

      <!-- Detalle de Servicios en Flujo Vertical -->
      <div class="space-y-20">
        {
          services.map((service, index) => {
            const isEven = index % 2 === 0;
            return (
              <div
                id={service.slug}
                class="flex scroll-mt-24 flex-col items-center gap-12 border-b border-slate-200 pb-16 last:border-0 lg:flex-row dark:border-slate-800"
              >
                {/* Columna Texto */}
                <div
                  class={`reveal w-full space-y-6 lg:w-1/2 ${!isEven ? 'lg:order-last' : ''}`}
                  data-reveal-direction={isEven ? 'left' : 'right'}
                  data-reveal-duration="0.8"
                >
                  <div class="flex items-center space-x-4">
                    <div class="bg-primary/10 text-primary dark:bg-primary/20 dark:text-accent flex h-14 w-14 items-center justify-center rounded-xl">
                      <Fragment set:html={icons[service.icon] || icons.web} />
                    </div>
                    <h2 class="text-secondary text-2xl font-extrabold sm:text-3xl dark:text-white">
                      {service.title}
                    </h2>
                  </div>
                  <p class="text-sm leading-relaxed text-slate-600 dark:text-slate-400">
                    {service.longDescription}
                  </p>
                  <div class="flex flex-wrap gap-4">
                    <a
                      href="/contacto/"
                      class="bg-primary hover:bg-primary-hover inline-flex items-center justify-center rounded-lg px-4 py-2 text-sm font-semibold text-white shadow-sm transition-all hover:shadow"
                    >
                      Cotizar este servicio
                    </a>
                  </div>
                </div>

                {/* Columna Decoración / Ilustración Visual */}
                <div
                  class="reveal w-full lg:w-1/2"
                  data-reveal-direction={isEven ? 'right' : 'left'}
                  data-reveal-duration="0.8"
                  data-reveal-delay="0.1"
                >
                  <div class="group relative rounded-2xl border border-slate-200 bg-white p-8 shadow-sm transition-all hover:shadow dark:border-slate-800 dark:bg-slate-900">
                    {/* Icono Decorativo Gigante en el fondo */}
                    <div class="pointer-events-none absolute right-4 bottom-4 translate-x-2 translate-y-2 transform text-slate-100 transition-transform duration-300 select-none group-hover:scale-110 dark:text-slate-800/40">
                      <div class="h-32 w-32 opacity-25">
                        <Fragment set:html={icons[service.icon] || icons.web} />
                      </div>
                    </div>

                    <h3 class="text-lg font-bold text-slate-800 dark:text-slate-200">
                      Características Principales
                    </h3>
                    <ul class="mt-4 space-y-3">
                      <li class="flex items-start gap-2 text-sm text-slate-600 dark:text-slate-400">
                        <svg
                          class="h-5 w-5 flex-shrink-0 text-emerald-500"
                          fill="none"
                          viewBox="0 0 24 24"
                          stroke="currentColor"
                        >
                          <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2.5"
                            d="M5 13l4 4L19 7"
                          />
                        </svg>
                        Optimización de velocidad (100% estático).
                      </li>
                      <li class="flex items-start gap-2 text-sm text-slate-600 dark:text-slate-400">
                        <svg
                          class="h-5 w-5 flex-shrink-0 text-emerald-500"
                          fill="none"
                          viewBox="0 0 24 24"
                          stroke="currentColor"
                        >
                          <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2.5"
                            d="M5 13l4 4L19 7"
                          />
                        </svg>
                        Seguridad ante ataques (JAMstack sin Base de Datos
                        expuesta).
                      </li>
                      <li class="flex items-start gap-2 text-sm text-slate-600 dark:text-slate-400">
                        <svg
                          class="h-5 w-5 flex-shrink-0 text-emerald-500"
                          fill="none"
                          viewBox="0 0 24 24"
                          stroke="currentColor"
                        >
                          <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2.5"
                            d="M5 13l4 4L19 7"
                          />
                        </svg>
                        Diseño adaptativo móvil (Responsive Design).
                      </li>
                    </ul>
                  </div>
                </div>
              </div>
            );
          })
        }
      </div>
    </div>
  </main>
</PageLayout>
