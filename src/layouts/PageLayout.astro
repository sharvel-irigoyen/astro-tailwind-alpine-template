---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import WhatsAppButton from '../components/layout/WhatsAppButton.astro';
import CookieBanner from '../components/layout/CookieBanner.astro';

interface Props {
  title?: string;
  description?: string;
  noindex?: boolean;
  ogImage?: string;
}

const { title, description, noindex, ogImage } = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  noindex={noindex}
  ogImage={ogImage}
>
  <Header />
  <main>
    <slot />
  </main>
  <Footer />
  <WhatsAppButton />
  <CookieBanner />
</BaseLayout>
