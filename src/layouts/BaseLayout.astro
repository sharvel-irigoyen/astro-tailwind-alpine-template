---
import '../styles/global.css';
import { siteConfig } from '../config/site';
import LocalBusinessSchema from '../components/seo/LocalBusinessSchema.astro';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
  noindex?: boolean;
  ogImage?: string;
}

const {
  title = `${siteConfig.name} | ${siteConfig.tagline}`,
  description = siteConfig.description,
  noindex = false,
  ogImage = '/og-image.png',
} = Astro.props;

// Intentar usar Astro.site; si no está configurado, usar la URL de la configuración
const siteUrl = Astro.site?.href || siteConfig.url;
const canonicalURL = new URL(Astro.url.pathname, siteUrl);
const ogImageURL = new URL(ogImage, siteUrl).href;
---

<!doctype html>
<html
  lang="es"
  data-allow-toggle={siteConfig.theme.allowToggle.toString()}
  data-default-mode={siteConfig.theme.defaultMode}
>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    {
      noindex ? (
        <meta name="robots" content="noindex, nofollow" />
      ) : (
        <meta name="robots" content="index, follow" />
      )
    }

    <link rel="canonical" href={canonicalURL.href} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <meta
      name="theme-color"
      content="#f9fafb"
      media="(prefers-color-scheme: light)"
    />
    <meta
      name="theme-color"
      content="#0f172a"
      media="(prefers-color-scheme: dark)"
    />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:site_name" content={siteConfig.name} />

    <!-- Twitter Cards -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- Astro View Transitions ClientRouter -->
    <ClientRouter />

    <!-- Script inline para evitar parpadeo de tema oscuro (FOUC) -->
    <script is:inline>
      const getTheme = () => {
        const doc = document.documentElement;
        const allowToggle = doc.getAttribute('data-allow-toggle') === 'true';
        const defaultMode = doc.getAttribute('data-default-mode') || 'system';
        if (!allowToggle) {
          if (defaultMode === 'system') {
            return window.matchMedia('(prefers-color-scheme: dark)').matches
              ? 'dark'
              : 'light';
          }
          return defaultMode;
        }
        if (
          typeof localStorage !== 'undefined' &&
          localStorage.getItem('theme')
        ) {
          return localStorage.getItem('theme');
        }
        return window.matchMedia('(prefers-color-scheme: dark)').matches
          ? 'dark'
          : 'light';
      };
      const applyTheme = () => {
        if (getTheme() === 'dark') {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
        }
      };
      applyTheme();
      document.addEventListener('astro:after-swap', applyTheme);

      // Añadir clase JS inmediatamente en render
      document.documentElement.classList.add('js');
    </script>

    <!-- Script de inicialización de animaciones de reveal -->
    <script>
      import { initReveal } from '../scripts/utils/reveal';

      // Ejecutar en la carga inicial
      initReveal();
      // Ejecutar tras navegaciones con View Transitions
      document.addEventListener('astro:page-load', initReveal);
    </script>

    <!-- Schema.org Local Business structured data -->
    {!noindex && <LocalBusinessSchema />}

    <!-- Umami Analytics -->
    {
      siteConfig.analytics?.umami?.enabled && (
        <script
          async
          defer
          src={siteConfig.analytics.umami.src}
          data-website-id={siteConfig.analytics.umami.websiteId}
        />
      )
    }

    <!-- Microsoft Clarity -->
    {
      siteConfig.analytics?.clarity?.enabled && (
        <script
          type="text/javascript"
          is:inline
          define:vars={{ projectId: siteConfig.analytics.clarity.projectId }}
          set:html={`
        (function(c,l,a,r,i,t,y){
            c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
            t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
            y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
        })(window, document, "clarity", "script", projectId);
      `}
        />
      )
    }

    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body
    class="bg-bg-light selection:bg-primary dark:bg-bg-dark min-h-screen text-slate-800 antialiased selection:text-white dark:text-slate-100"
  >
    <slot />
  </body>
</html>
