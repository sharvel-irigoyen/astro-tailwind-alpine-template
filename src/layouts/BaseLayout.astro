---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Astro + Tailwind + Alpine Template',
  description = 'Plantilla base optimizada para proyectos con Astro, Tailwind CSS y Alpine.js',
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body
    class="min-h-screen bg-gray-50 text-gray-900 antialiased selection:bg-blue-500 selection:text-white dark:bg-gray-900 dark:text-gray-100"
  >
    <slot />
  </body>
</html>
